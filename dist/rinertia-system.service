[Unit]
Description=rinertia pointer inertia daemon for Linux touchpads
After=systemd-udevd.service local-fs.target
Wants=systemd-udevd.service

[Service]
Type=simple
ExecStart=/usr/local/bin/rinertia --config /etc/rinertia/config.toml
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
