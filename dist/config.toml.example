# rinertia pointer-inertia example config
# All fields are optional. CLI arguments override config values.
# Omitted fields use built-in defaults.

log_level = "info"
# decision_log = "/tmp/rinertia-decisions.log"

[device]
# path = "/dev/input/event9"
# name = "ELAN"

[pointer]
drag = 0.01
speed_factor = 0.0075
min_velocity = 100.0
velocity_stale_ms = 150
